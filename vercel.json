{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/app.py" },
    { "src": "/ws/(.*)", "dest": "/server/app.py" },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot|json|map))$",
      "dest": "/client/$1"
    },
    { "src": "/(.*)", "dest": "/client/index.html" }
  ]
}
